{
  "name": "dattools",
  "version": "1.13.0",
  "description": "Toolkit for Chip's Challenge DAT levelsets (multiple 32x32 levels per file).",
  "main": "index.js",
  "scripts": {
    "test": "vitest run",
    "build": "tsup",
    "build_walls": "tsx scripts/build_walls.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json --noEmit && tsc -p web/tsconfig.json --noEmit",
    "test:watch": "vitest",
    "tauri": "tauri",
    "dev:web": "vite",
    "dev:desktop": "tauri dev",
    "generate:desktop-icon": "python3 scripts/generate_desktop_icon.py && npm run tauri -- icon src-tauri/app-icon.png --output src-tauri/icons",
    "build:web": "vite build",
    "build:web:pages": "vite build --mode pages",
    "build:desktop": "tauri build",
    "preview:web": "vite preview",
    "fmt:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "fmt:write": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/joshua-bone/DATTools.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/joshua-bone/DATTools/issues"
  },
  "homepage": "https://joshua-bone.github.io/DATTools/",
  "dependencies": {
    "@tauri-apps/api": "2.10.1",
    "@tauri-apps/plugin-dialog": "2.6.0",
    "@tauri-apps/plugin-fs": "2.4.5",
    "@tauri-apps/plugin-opener": "2.5.3",
    "commander": "^14.0.2",
    "fflate": "^0.8.2",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "@tauri-apps/cli": "2.10.1",
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "husky": "^9.1.7",
    "prettier": "^3.7.4",
    "tsx": "^4.20.6",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.0",
    "vitest": "^4.0.16"
  },
  "bin": {
    "dattools": "dist/cli.js"
  }
}
