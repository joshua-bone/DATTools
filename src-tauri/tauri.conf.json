{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "DATTools",
  "version": "../package.json",
  "identifier": "io.github.joshua-bone.dattools",
  "build": {
    "frontendDist": "../dist-web",
    "devUrl": "http://127.0.0.1:1420",
    "beforeDevCommand": "npm run dev:web -- --host 127.0.0.1 --port 1420 --strictPort",
    "beforeBuildCommand": "npm run build:web"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "DATTools",
        "width": 1440,
        "height": 960,
        "minWidth": 1024,
        "minHeight": 720,
        "center": true,
        "dragDropEnabled": false,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "Joshua Bone",
    "homepage": "https://github.com/joshua-bone/DATTools",
    "icon": [
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "copyright": "Copyright (c) 2026 Joshua Bone",
    "license": "ISC",
    "licenseFile": "../LICENSE",
    "category": "DeveloperTool",
    "shortDescription": "Offline editor for Chip's Challenge DAT levelsets.",
    "longDescription": "DATTools is a desktop editor for Chip's Challenge DAT levelsets with palette painting, metadata editing, transforms, undo, and DAT/3D level support."
  }
}
