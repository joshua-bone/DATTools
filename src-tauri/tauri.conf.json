{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "DATTools",
  "version": "1.0.0",
  "identifier": "io.github.joshua-bone.dattools",
  "build": {
    "frontendDist": "../dist-web",
    "devUrl": "http://127.0.0.1:1420",
    "beforeDevCommand": "npm run dev:web -- --host 127.0.0.1 --port 1420 --strictPort",
    "beforeBuildCommand": "npm run build:web"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "DATTools",
        "width": 1440,
        "height": 960,
        "minWidth": 1024,
        "minHeight": 720,
        "center": true,
        "dragDropEnabled": false,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
